{
  "$schema": "../../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Mycelium",
  "version": "0.63.0",
  "identifier": "io.mycelium.desktop",
  "build": {
    "frontendDist": "./resources/frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mycelium",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: blob: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://github.com https://raw.githubusercontent.com https://objects.githubusercontent.com; frame-src 'none'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "appimage", "dmg"],
    "category": "Productivity",
    "shortDescription": "Local-first, end-to-end encrypted, peer-to-peer knowledge workspace",
    "longDescription": "Mycelium is a single-binary application that gives you a personal knowledge workspace that lives on your devices, syncs directly between them peer-to-peer, encrypts everything end-to-end, and lets you find anything by meaning thanks to a language model running on your own machine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "createUpdaterArtifacts": true,
    "windows": {
      "wix": {
        "language": ["en-US", "fr-FR"]
      },
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "compression": "lzma",
        "languages": ["English", "French"],
        "startMenuFolder": "Mycelium"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://raw.githubusercontent.com/Arka-ui/mycelium/main/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYwRkMyRTQyRDFDOUI4MkUKUldRdXVNblJRaTc4WU9VQVBudTZNMUtXQU5mYmp0YytPWDllempPN1MyZWlXcXU1UDBGSDBYOFIK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
